spring.application.name=joby
spring.datasource.url=jdbc:postgresql://localhost:5432/joby
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.jpa.hibernate.ddl-auto=validate
spring.flyway.enabled=true
spring.jpa.open-in-view=false

logging.pattern.console=%d{HH:mm:ss} [%t] %-5level %logger{20} - %msg%n
spring.devtools.restart.enabled=true

springdoc.swagger-ui.path=/swagger-ui
springdoc.api-docs.path=/api-docs

management.endpoints.web.exposure.include=health,info,metrics,prometheus
management.endpoint.health.show-details=always
spring.web.resources.add-mappings=false

spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.max-lifetime=1200000

spring.kafka.bootstrap-servers=localhost:9092
spring.kafka.producer.key-serializer=org.apache.kafka.common.serialization.StringSerializer
spring.kafka.producer.value-serializer=org.apache.kafka.common.serialization.StringSerializer
spring.kafka.consumer.group-id=joby-workers
spring.kafka.consumer.key-deserializer=org.apache.kafka.common.serialization.StringDeserializer
spring.kafka.consumer.value-deserializer=org.apache.kafka.common.serialization.StringDeserializer
spring.kafka.consumer.auto-offset-reset=earliest

joby.api-key=YOUR_API_KEY
joby.worker.threads=5

logging.level.org.apache.kafka=WARN
logging.level.org.springframework.kafka=WARN